{
  "name": "@omnicore/age-verification",
  "version": "1.0.0",
  "description": "Age Verification Module for Dynamic Trust Engine",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./src/react/index.ts",
      "default": "./src/react/index.ts"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": ["dist/", "LICENSE", "README.md"],
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "test-server": "cd test-server && npm install && npm run serve",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": { "node": ">=20" },
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.18"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0"
  }
}